---
import Layout from '../layouts/Layout.astro';

const mitos = [
  {
    title: "La Telesita",
    description: "La bailarina que murió de sed y fuego en el monte santiagueño",
    category: "Leyenda",
    slug: "la-telesita",
    color: "cyan"
  },
  {
    title: "El Kakuy",
    description: "El hombre pájaro que vive en lo profundo del monte",
    category: "Mito",
    slug: "el-kakuy",
    color: "purple"
  },
  {
    title: "El Crespín",
    description: "El duende de la suerte que habita en las casas santiagueñas",
    category: "Leyenda",
    slug: "el-crespin",
    color: "green"
  },
  {
    title: "La Dama de Blanco",
    description: "El alma en pena que vaga por las calles del centro histórico",
    category: "Leyenda",
    slug: "la-dama-de-blanco",
    color: "pink"
  },
  {
    title: "El Nahuelito",
    description: "La criatura acuática que habita en las profundidades del río Dulce",
    category: "Mito",
    slug: "el-nahuelito",
    color: "blue"
  }
];
---

<Layout title="Mitos Santiagueños" description="Colección de mitos, leyendas y relatos tradicionales de Santiago del Estero, Argentina">
  
  <!-- Hero Section -->
  <section class="text-center mb-20 pt-8">
    <div class="inline-block mb-6">
      <span class="px-4 py-2 rounded-full border border-cyan-500/50 text-cyan-400 text-sm font-mono tracking-widest uppercase bg-cyan-500/10">
        Folclore Argentino
      </span>
    </div>
    
    <h1 class="text-6xl md:text-8xl font-bold mb-6 font-['Space_Grotesk'] tracking-tighter">
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-white to-purple-400 glow-text">
        MITOS
      </span>
      <span class="block text-4xl md:text-6xl text-gray-500 mt-2">SANTIAGUEÑOS</span>
    </h1>
    
    <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
      Descubre las fascinantes historias que han pasado de generación en generación 
      en <span class="text-cyan-400">Santiago del Estero</span>. Leyendas de amor, terror, 
      magia y misterio que forman parte del rico folclore santiagueño.
    </p>
    
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a 
        href="/historietas"
        class="cyber-button px-8 py-4 font-mono text-sm tracking-widest uppercase"
      >
        Ver Historietas
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-3 gap-8 mb-20 py-8 border-y border-cyan-500/20">
    <div class="text-center">
      <div class="text-4xl font-bold text-cyan-400 font-['Space_Grotesk']">05</div>
      <div class="text-sm text-gray-500 uppercase tracking-widest mt-2">Mitos</div>
    </div>
    <div class="text-center">
      <div class="text-4xl font-bold text-purple-400 font-['Space_Grotesk']">10</div>
      <div class="text-sm text-gray-500 uppercase tracking-widest mt-2">Escenas</div>
    </div>
    <div class="text-center">
      <div class="text-4xl font-bold text-pink-400 font-['Space_Grotesk']">30</div>
      <div class="text-sm text-gray-500 uppercase tracking-widest mt-2">Prompts</div>
    </div>
  </section>

  <!-- Mitos Grid -->
  <section class="mb-20">
    <div class="flex items-center gap-4 mb-10">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
      <h2 class="text-2xl font-bold font-['Space_Grotesk'] text-cyan-400 tracking-widest">COLECCIÓN</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {mitos.map((mito, index) => (
        <a 
          href={`/mitos/${mito.slug}`}
          class="cyber-card block bg-gray-900/50 backdrop-blur-sm p-6 group"
        >
          <div class="flex items-start justify-between mb-4">
            <span class={`text-xs font-mono px-3 py-1 rounded-full border ${
              mito.color === 'cyan' ? 'border-cyan-500/50 text-cyan-400 bg-cyan-500/10' :
              mito.color === 'purple' ? 'border-purple-500/50 text-purple-400 bg-purple-500/10' :
              mito.color === 'green' ? 'border-green-500/50 text-green-400 bg-green-500/10' :
              mito.color === 'pink' ? 'border-pink-500/50 text-pink-400 bg-pink-500/10' :
              'border-blue-500/50 text-blue-400 bg-blue-500/10'
            }`}>
              {mito.category}
            </span>
            <span class="text-3xl font-bold text-gray-700 font-['Space_Grotesk']">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>
          
          <h3 class="text-xl font-bold mb-3 text-white group-hover:text-cyan-400 transition-colors font-['Space_Grotesk']">
            {mito.title}
          </h3>
          
          <p class="text-gray-400 text-sm leading-relaxed">{mito.description}</p>
          
          <div class="mt-6 flex items-center text-cyan-400 text-sm font-mono">
            <span>Leer más</span>
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="text-center py-16 border border-cyan-500/30 bg-gradient-to-b from-cyan-500/5 to-transparent">
    <h2 class="text-3xl font-bold mb-4 font-['Space_Grotesk']">
      ¿Querés ver las <span class="text-cyan-400">historietas</span>?
    </h2>
    
    <p class="text-gray-400 mb-8 max-w-xl mx-auto">
      Cada mito cuenta con guiones para historietas y prompts listos para generar 
      imágenes con IA. Explorá las escenas ilustradas.
    </p>
    
    <a 
      href="/historietas"
      class="inline-block bg-cyan-500 hover:bg-cyan-400 text-black font-bold px-8 py-4 font-mono text-sm tracking-widest uppercase transition-all hover:shadow-[0_0_30px_rgba(6,182,212,0.5)]"
    >
      Explorar Historietas
    </a>
  </section>

</Layout>
