---
import Layout from '../layouts/Layout.astro';

const mitos = [
  {
    title: "La Telesita",
    description: "La bailarina que murió de sed y fuego en el monte santiagueño",
    category: "Leyenda",
    slug: "la-telesita"
  },
  {
    title: "El Kakuy",
    description: "El hombre pájaro que vive en lo profundo del monte",
    category: "Mito",
    slug: "el-kakuy"
  },
  {
    title: "El Crespín",
    description: "El duende de la suerte que habita en las casas santiagueñas",
    category: "Leyenda",
    slug: "el-crespin"
  },
  {
    title: "La Dama de Blanco",
    description: "El alma en pena que vaga por las calles del centro histórico",
    category: "Leyenda",
    slug: "la-dama-de-blanco"
  },
  {
    title: "El Nahuelito",
    description: "La criatura acuática que habita en las profundidades del río Dulce",
    category: "Mito",
    slug: "el-nahuelito"
  }
];
---

<Layout title="Mitos Santiagueños" description="Colección de mitos, leyendas y relatos tradicionales de Santiago del Estero, Argentina">
  
  <!-- Hero Section -->
  <section class="text-center mb-16 pt-8">
    <div class="inline-block mb-6">
      <span class="px-4 py-2 rounded-full bg-orange-100 text-orange-700 text-sm font-medium">
        Folclore Argentino
      </span>
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold mb-6 font-['DM_Serif_Display'] text-slate-900">
      Mitos Santiagueños
    </h1>
    
    <p class="text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
      Descubre las fascinantes historias que han pasado de generación en generación 
      en <span class="text-orange-600 font-medium">Santiago del Estero</span>. Leyendas de amor, terror, 
      magia y misterio que forman parte del rico folclore santiagueño.
    </p>
    
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a 
        href="/historietas"
        class="btn-primary px-8 py-4 rounded-full font-medium"
      >
        Ver Historietas
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-3 gap-8 mb-16 py-8 border-y border-slate-200">
    <div class="text-center">
      <div class="text-4xl font-bold text-slate-900 font-['DM_Serif_Display']">5</div>
      <div class="text-sm text-slate-500 mt-1">Mitos</div>
    </div>
    <div class="text-center">
      <div class="text-4xl font-bold text-slate-900 font-['DM_Serif_Display']">10</div>
      <div class="text-sm text-slate-500 mt-1">Escenas</div>
    </div>
    <div class="text-center">
      <div class="text-4xl font-bold text-slate-900 font-['DM_Serif_Display']">30</div>
      <div class="text-sm text-slate-500 mt-1">Prompts</div>
    </div>
  </section>

  <!-- Mitos Grid -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold font-['DM_Serif_Display'] text-slate-900 text-center mb-10">
      Colección de Relatos
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {mitos.map((mito, index) => (
        <a 
          href={`/mitos/${mito.slug}`}
          class="myth-card block bg-white rounded-2xl p-6 group"
        >
          <div class="flex items-start justify-between mb-4">
            <span class="text-xs font-medium px-3 py-1 rounded-full bg-slate-100 text-slate-600">
              {mito.category}
            </span>
            <span class="text-2xl font-bold text-slate-200 font-['DM_Serif_Display']">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>
          
          <h3 class="text-xl font-bold mb-3 text-slate-900 group-hover:text-orange-600 transition-colors font-['DM_Serif_Display']">
            {mito.title}
          </h3>
          
          <p class="text-slate-600 text-sm leading-relaxed">{mito.description}</p>
          
          <div class="mt-6 flex items-center text-orange-600 text-sm font-medium">
            <span>Leer más</span>
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="text-center py-16 bg-gradient-to-br from-orange-50 to-amber-50 rounded-3xl">
    <h2 class="text-3xl font-bold mb-4 font-['DM_Serif_Display'] text-slate-900">
      ¿Querés ver las <span class="text-orange-600">historietas</span>?
    </h2>
    
    <p class="text-slate-600 mb-8 max-w-xl mx-auto">
      Cada mito cuenta con guiones para historietas y prompts listos para generar 
      imágenes con IA. Explorá las escenas ilustradas.
    </p>
    
    <a 
      href="/historietas"
      class="btn-primary px-8 py-4 rounded-full font-medium inline-block"
    >
      Explorar Historietas
    </a>
  </section>

</Layout>
