---
import Layout from '../layouts/Layout.astro';

const mitos = [
  {
    title: "El Sachayoj",
    description: "El Dios protector de los bosques. Viejo canoso que cuida el monte y castiga a quienes destruyen la naturaleza.",
    category: "Leyenda",
    slug: "el-sachayoj"
  },
  {
    title: "La Mayu Maman",
    description: "La sirena de nuestros ríos. Hermosa mujer rubia que peina su cabellera con peine de oro y arrastra a los hombres al agua.",
    category: "Leyenda",
    slug: "la-mayu-maman"
  },
  {
    title: "El Pampayoj",
    description: "Dueño y señor de las llanuras. Protege la fauna y castiga la caza furtiva. Aparece como jinete, avestruz o guanaco.",
    category: "Leyenda",
    slug: "el-pampayoj"
  },
  {
    title: "La Uritu Orko",
    description: "Mujer sentada en la cumbre de una roca. Personifica la tragedia de quienes desconocen el peligro de las serranías.",
    category: "Leyenda",
    slug: "la-uritu-orko"
  },
  {
    title: "La Salamanca",
    description: "Lugar oculto entre los breñales donde el Diablo enseña sus artes. Aquelarres, música y orgías en la oscuridad.",
    category: "Leyenda",
    slug: "la-salamanca"
  },
  {
    title: "El Kakuy",
    description: "Pájaro que fue mujer. Castigada por su crueldad hacia su hermano, vaga llamando incesantemente '¡Kakuy, turay, turay!'",
    category: "Leyenda",
    slug: "el-kakuy"
  },
  {
    title: "El Crespín",
    description: "Mujer transformada en pájaro por abandonar a su esposo moribundo. Llama incesantemente 'Crespín... Crespín...'",
    category: "Leyenda",
    slug: "el-crespin"
  },
  {
    title: "El Runauturungo",
    description: "Tigre demoníaco que aterrorizaba las estancias. El bien triunfa sobre el mal cuando el cazador lo derrota.",
    category: "Leyenda",
    slug: "el-runauturungo"
  },
  {
    title: "El Toro Yacu",
    description: "Toro negro con cuernos de oro. Manifestación del mal que protege riquezas a cambio del alma.",
    category: "Leyenda",
    slug: "el-toro-yacu"
  },
  {
    title: "La Telesita",
    description: "Niña huérfana que murió quemada bailando. Alma milagrosa invocada para pedir lluvia en épocas de sequía.",
    category: "Leyenda",
    slug: "la-telesita"
  },
  {
    title: "El Supay",
    description: "Genio del mal con capacidad metamorfósica. Se manifiesta como viento Huayra Muyoj o en la Salamanca.",
    category: "Leyenda",
    slug: "el-supay"
  },
  {
    title: "La Almamula",
    description: "Mula que fue mujer. Castigada por incesto o relaciones con curas, vaga con cadenas echando fuego por los ojos.",
    category: "Leyenda",
    slug: "la-almamula"
  }
];
---

<Layout title="Mitos Santiagueños" description="Colección de mitos, leyendas y relatos tradicionales de Santiago del Estero, Argentina">
  
  <!-- Hero Section -->
  <section class="text-center mb-16 pt-8">
    <div class="inline-block mb-6">
      <span class="px-4 py-2 rounded-full bg-orange-100 text-orange-700 text-sm font-medium">
        Folclore Argentino
      </span>
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold mb-6 font-['DM_Serif_Display'] text-slate-900">
      Mitos Santiagueños
    </h1>
    
    <p class="text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
      Creencias populares, mitos y leyendas transmitidos de generación en generación
      en <span class="text-orange-600 font-medium">Santiago del Estero</span>.
      Recopilación basada en múltiples fuentes históricas, culturales y académicas.
    </p>
    
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a 
        href="/historietas"
        class="btn-primary px-8 py-4 rounded-full font-medium"
      >
        Ver Historietas
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-3 gap-8 mb-16 py-8 border-y border-slate-200">
    <div class="text-center">
      <div class="text-4xl font-bold text-slate-900 font-['DM_Serif_Display']">12</div>
      <div class="text-sm text-slate-500 mt-1">Leyendas</div>
    </div>
    <div class="text-center">
      <div class="text-4xl font-bold text-slate-900 font-['DM_Serif_Display']">24</div>
      <div class="text-sm text-slate-500 mt-1">Escenas</div>
    </div>
    <div class="text-center">
      <div class="text-4xl font-bold text-slate-900 font-['DM_Serif_Display']">36</div>
      <div class="text-sm text-slate-500 mt-1">Prompts</div>
    </div>
  </section>

  <!-- Mitos Grid -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold font-['DM_Serif_Display'] text-slate-900 text-center mb-10">
      Colección de Relatos
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {mitos.map((mito, index) => (
        <a 
          href={`/mitos/${mito.slug}`}
          class="myth-card block bg-white rounded-2xl p-6 group"
        >
          <div class="flex items-start justify-between mb-4">
            <span class="text-xs font-medium px-3 py-1 rounded-full bg-orange-100 text-orange-700">
              {mito.category}
            </span>
            <span class="text-2xl font-bold text-slate-200 font-['DM_Serif_Display']">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>
          
          <h3 class="text-xl font-bold mb-3 text-slate-900 group-hover:text-orange-600 transition-colors font-['DM_Serif_Display']">
            {mito.title}
          </h3>
          
          <p class="text-slate-600 text-sm leading-relaxed">{mito.description}</p>
          
          <div class="mt-6 flex items-center text-orange-600 text-sm font-medium">
            <span>Leer más</span>
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="text-center py-16 bg-gradient-to-br from-orange-50 to-amber-50 rounded-3xl">
    <h2 class="text-3xl font-bold mb-4 font-['DM_Serif_Display'] text-slate-900">
      ¿Querés ver las <span class="text-orange-600">historietas</span>?
    </h2>
    
    <p class="text-slate-600 mb-8 max-w-xl mx-auto">
      Cada mito cuenta con guiones para historietas y prompts listos para generar 
      imágenes con IA. Explorá las escenas ilustradas.
    </p>
    
    <a 
      href="/historietas"
      class="btn-primary px-8 py-4 rounded-full font-medium inline-block"
    >
      Explorar Historietas
    </a>
  </section>

</Layout>
