---

<Layout title="Historietas - Mitos Santiagueños" description="Historietas ilustradas de los mitos y leyendas de Santiago del Estero">
  
  <!-- Header -->
  <section class="text-center mb-16">
    <span class="inline-block px-4 py-2 rounded-full bg-orange-100 text-orange-700 text-sm font-medium mb-4">
      Ilustraciones
    </span>
    
    <h1 class="text-5xl font-bold mb-6 font-['DM_Serif_Display'] text-slate-900">
      Historietas
    </h1>
    
    <p class="text-xl text-slate-600 max-w-2xl mx-auto">
      Cada leyenda cuenta con <strong class="text-orange-600">2 escenas ilustradas</strong> listas para generar con IA. 
      Cada historieta tiene su propia página con los prompts optimizados.
    </p>
  </section>

  <!-- Grid de Historietas -->
  <section class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
    {historietas.map((historieta, index) => (
      <a 
        href={`/historietas/${historieta.slug}`}
        class="myth-card block bg-white rounded-2xl p-6 group"
      >
        <div class="flex items-start justify-between mb-4">
          <span class="text-xs font-medium px-3 py-1 rounded-full bg-orange-100 text-orange-700">
            {historieta.escenas.length} escenas
          </span>
          <span class="text-2xl font-bold text-slate-200 font-['DM_Serif_Display']">
            {String(index + 1).padStart(2, '0')}
          </span>
        </div>
        
        <h2 class="text-xl font-bold mb-3 text-slate-900 group-hover:text-orange-600 transition-colors font-['DM_Serif_Display']">
          {historieta.title}
        </h2>
        
        <p class="text-slate-600 text-sm mb-4">{historieta.escenas[0].descripcion.substring(0, 100)}...</p>
        
        <div class="flex items-center text-orange-600 text-sm font-medium">
          <span>Ver historieta</span>
          <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>
    ))}
  </section>

  <!-- Info -->
  <section class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-3xl p-8 text-center">
    <h2 class="text-2xl font-bold mb-4 font-['DM_Serif_Display'] text-slate-900">
      ¿Cómo usar los prompts?
    </h2>    
    <p class="text-slate-600 mb-6 max-w-xl mx-auto">
      Cada escena incluye un prompt optimizado para generar imágenes con IA. 
      Podés usar Gemini, Midjourney, DALL-E o cualquier herramienta de generación de imágenes.
    </p>    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a 
        href="https://gemini.google.com"
        target="_blank"
        rel="noopener"
        class="btn-primary px-6 py-3 rounded-full font-medium"
      >
        Abrir Gemini
      </a>
    </div>
  </section>

</Layout>
