export async function getStaticPaths() {
  const mitos = [
    { slug: 'el-sachayoj', title: 'El Sachayoj' },
    { slug: 'la-mayu-maman', title: 'La Mayu Maman' },
    { slug: 'el-pampayoj', title: 'El Pampayoj' },
    { slug: 'la-uritu-orko', title: 'La Uritu Orko' },
    { slug: 'la-salamanca', title: 'La Salamanca' },
    { slug: 'el-kakuy', title: 'El Kakuy' },
    { slug: 'el-crespin', title: 'El Crespín' },
    { slug: 'el-runauturungo', title: 'El Runauturungo' },
    { slug: 'el-toro-yacu', title: 'El Toro Yacu' },
    { slug: 'la-telesita', title: 'La Telesita' },
    { slug: 'el-supay', title: 'El Supay' },
    { slug: 'la-almamula', title: 'La Almamula' },
    { slug: 'el-tanicu', title: 'El Tanicu' },
    { slug: 'el-ckaparilo', title: 'El Ckaparilo' },
    { slug: 'la-umita', title: 'La Umita' },
    { slug: 'el-linyerita', title: 'El Linyerita' }
  ];

  return mitos.map(mito => ({
    params: { slug: mito.slug },
    props: { mito }
  }));
}

const { mito } = Astro.props;
const fuentesData = fuentesPorMito[mito.slug] || { fuentes: [] };

// Leer contenido del archivo
let contenido = { historia: '', escenas: [], guion: '' };
try {
  const filePath = join(process.cwd(), 'contenido', `${mito.slug}-completo.md`);
  const fileContent = readFileSync(filePath, 'utf-8');
  
  const historiaMatch = fileContent.match(/## Historia Completa\n\n([\s\S]*?)(?=\n## Historieta|$)/);
  const historietaMatch = fileContent.match(/## Historieta\n\n([\s\S]*?)(?=\n## Guion|$)/);
  const guionMatch = fileContent.match(/## Guion para Corto[^\n]*\n\n([\s\S]*?)$/);
  
  // Parsear escenas de la historieta
  const escenasRaw = historietaMatch ? historietaMatch[1].trim() : '';
  const escenas = [];
  const escenaBlocks = escenasRaw.split('### Escena').filter(Boolean);
  
  for (const block of escenaBlocks) {
    const lines = block.trim().split('\n');
    const tituloLine = lines[0] || '';
    const titulo = tituloLine.replace(':', '').trim();
    
    let descripcion = '';
    let dialogo = '';
    let prompt = '';
    
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (line.startsWith('**Diálogo:**')) {
        dialogo = line.replace('**Diálogo:**', '').trim();
      } else if (line.startsWith('**Prompt:**')) {
        prompt = line.replace('**Prompt:**', '').trim();
      } else if (line && !line.startsWith('**')) {
        descripcion = line;
      }
    }
    
    if (titulo && descripcion) {
      escenas.push({ titulo, descripcion, dialogo, prompt });
    }
  }
  
  contenido = {
    historia: historiaMatch ? historiaMatch[1].trim() : '',
    escenas: escenas,
    guion: guionMatch ? guionMatch[1].trim() : ''
  };
} catch (e) {
  console.error('Error leyendo archivo:', e);
}
---

<Layout title={mito.title} description={`Leyenda de ${mito.title} - Múltiples fuentes: CCB Santiago, Santiago Educativo, Diccionario de Mitos y Leyendas, Alero Quichua`}>
  <article class="max-w-4xl mx-auto">
    <a href="/" class="inline-flex items-center text-orange-600 hover:text-orange-700 mb-6 transition-colors">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Volver al inicio
    </a>

    <header class="mb-8">
      <span class="inline-block px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-sm font-medium mb-4">
        Leyenda Santiagueña
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 font-['DM_Serif_Display'] mb-4">
        {mito.title}
      </h1>
      <div class="h-1 w-24 bg-orange-500 rounded"></div>
    </header>

    <div class="mb-8">
      <div class="flex flex-wrap border-b border-slate-200">
        <button id="tab-historia" class="tab-btn px-4 py-3 text-sm font-medium text-orange-600 border-b-2 border-orange-600 bg-orange-50/50" onclick="switchTab('historia')">
          📖 Historia
        </button>
        <button id="tab-guion" class="tab-btn px-4 py-3 text-sm font-medium text-slate-600 border-b-2 border-transparent hover:text-orange-600" onclick="switchTab('guion')">
          🎬 Guión
        </button>
        <button id="tab-fuentes" class="tab-btn px-4 py-3 text-sm font-medium text-slate-600 border-b-2 border-transparent hover:text-orange-600" onclick="switchTab('fuentes')">
          📚 Fuentes
        </button>
      </div>
    </div>

    <div id="content-historia" class="tab-content">
      <div class="prose prose-lg max-w-none text-slate-700 leading-relaxed">
        {contenido.historia.split('\n\n').map((parrafo) => (
          <p class="mb-4 text-lg leading-relaxed">{parrafo}</p>
        ))}
      </div>

      {contenido.escenas.length > 0 && (
        <div class="mt-12 pt-8 border-t-2 border-orange-200">
          <h2 class="text-2xl font-bold text-slate-900 font-['DM_Serif_Display'] mb-6 flex items-center gap-2">
            <span>🎨</span> Escenas Ilustradas
          </h2>
          <p class="text-slate-600 mb-6">Visualizaciones clave de la historia para comprender mejor el relato:</p>
          
          <div class="space-y-8">
            {contenido.escenas.map((escena, i) => (
              <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
                <h3 class="text-xl font-bold text-slate-900 font-['DM_Serif_Display'] mb-3">
                  Escena {i + 1}: {escena.titulo}
                </h3>
                <p class="text-slate-700 mb-4">{escena.descripcion}</p>
                {escena.dialogo && (
                  <div class="bg-white rounded-lg p-4 mb-4 border-l-4 border-orange-500">
                    <p class="text-sm text-slate-500 mb-1">Diálogo:</p>
                    <p class="text-slate-800 italic">{escena.dialogo}</p>
                  </div>
                )}
                {escena.prompt && (
                  <div class="bg-slate-100 rounded-lg p-4 border border-slate-300">
                    <div class="flex items-center justify-between mb-2">
                      <p class="text-sm font-medium text-slate-700">🎨 Descripción para ilustración:</p>
                      <button 
                        onclick="copyPrompt(this, '{escena.prompt.replace(/'/g, "\\'")}')"
                        class="text-xs px-3 py-1 bg-orange-600 text-white rounded hover:bg-orange-700 transition-colors"
                      >
                        Copiar
                      </button>
                    </div>
                    <code class="text-xs text-slate-600 block break-words bg-white p-3 rounded border border-slate-200">{escena.prompt}</code>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <div id="content-guion" class="tab-content hidden">
      <div class="bg-slate-900 text-slate-100 rounded-xl p-6 font-mono text-sm overflow-x-auto">
        <pre class="whitespace-pre-wrap">{contenido.guion}</pre>
      </div>
    </div>

    <div id="content-fuentes" class="tab-content hidden">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-slate-900 font-['DM_Serif_Display'] mb-6">
          📚 Fuentes y Referencias
        </h2>
        <p class="text-slate-600 mb-6">
          Esta leyenda ha sido recopilada de múltiples fuentes para ofrecer una visión completa y fidedigna del folklore santiagueño.
        </p>
        
        <div class="space-y-4">
          {fuentesData.fuentes.map((fuente: any) => (
            <div class="bg-slate-50 rounded-xl p-5 border border-slate-200 hover:border-orange-300 transition-colors">
              <div class="flex flex-wrap items-start justify-between gap-2">
                <h3 class="font-bold text-slate-900 text-lg">{fuente.nombre}</h3>
                <span class="px-2 py-1 bg-orange-100 text-orange-700 text-xs rounded-full">{fuente.tipo}</span>
              </div>
              <p class="text-slate-600 mt-2">{fuente.descripcion}</p>
              <a href={fuente.url} target="_blank" rel="noopener" class="inline-flex items-center text-orange-600 hover:text-orange-700 text-sm mt-3">
                Visitar fuente
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-orange-50 rounded-xl p-6 border border-orange-200">
        <h3 class="text-lg font-bold text-slate-900 mb-4">📖 Bibliografía Recomendada</h3>
        <ul class="space-y-3 text-slate-700">
          <li class="flex items-start">
            <span class="text-orange-500 mr-2">•</span>
            <div>
              <strong>Di Lullo, Orestes</strong> - "El Folklore de Santiago del Estero" (1943)
              <p class="text-sm text-slate-500">Universidad Nacional de Tucumán</p>
            </div>
          </li>
          <li class="flex items-start">
            <span class="text-orange-500 mr-2">•</span>
            <div>
              <strong>Bathata, Tomás</strong> - "Mitos y Leyendas de Santiago del Estero"
              <p class="text-sm text-slate-500">Universitas Editorial</p>
            </div>
          </li>
          <li class="flex items-start">
            <span class="text-orange-500 mr-2">•</span>
            <div>
              <strong>Domínguez, Amalia Beatriz</strong> - Artículos en El Liberal (1988)
              <p class="text-sm text-slate-500">Suplemento Aniversario 90 Años</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="mt-8 pt-8 border-t border-slate-200">
        <h3 class="text-lg font-bold text-slate-900 mb-4">🎵 Canciones Relacionadas</h3>
        <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
          <h4 class="font-bold text-slate-900">"Tradiciones Santiagueñas"</h4>
          <p class="text-slate-600 text-sm mt-1">Folklore Argentino</p>
          <a href="https://www.cancioneros.com/letras/cancion/42098/tradiciones-santiaguenas-folklore-argentino" target="_blank" rel="noopener" class="text-orange-600 hover:underline text-sm">
            Ver letra completa
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-200">
      <p class="text-sm text-slate-500">
        <strong>Fuentes consultadas:</strong> Centro Cultural del Bicentenario Santiago, Santiago Educativo, Diccionario de Mitos y Leyendas (Cuco), Alero Quichua Santiagueño, y otras fuentes del folklore santiagueño.
      </p>
      <p class="text-xs text-slate-400 mt-2">
        Este contenido es una recopilación de múltiples fuentes históricas y culturales para preservar y difundir el folklore santiagueño.
      </p>
    </div>
  </article>

  <script is:inline>
    function switchTab(tabName) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.getElementById('content-' + tabName).classList.remove('hidden');
      
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('text-orange-600', 'border-orange-600', 'bg-orange-50/50');
        btn.classList.add('text-slate-600', 'border-transparent');
      });
      
      document.getElementById('tab-' + tabName).classList.remove('text-slate-600', 'border-transparent');
      document.getElementById('tab-' + tabName).classList.add('text-orange-600', 'border-orange-600', 'bg-orange-50/50');
    }
    
    function copyPrompt(btn, text) {
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.textContent;
        btn.textContent = '¡Copiado!';
        btn.classList.add('bg-green-600');
        btn.classList.remove('bg-orange-600');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('bg-green-600');
          btn.classList.add('bg-orange-600');
        }, 2000);
      });
    }
  </script>
</Layout>