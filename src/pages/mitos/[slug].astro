---
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  const mitos = [
    { slug: 'el-sachayoj', title: 'El Sachayoj' },
    { slug: 'la-mayu-maman', title: 'La Mayu Maman' },
    { slug: 'el-pampayoj', title: 'El Pampayoj' },
    { slug: 'la-uritu-orko', title: 'La Uritu Orko' },
    { slug: 'la-salamanca', title: 'La Salamanca' },
    { slug: 'el-kakuy', title: 'El Kakuy' },
    { slug: 'el-crespin', title: 'El Crespín' },
    { slug: 'el-runauturungo', title: 'El Runauturungo' },
    { slug: 'el-toro-yacu', title: 'El Toro Yacu' },
    { slug: 'la-telesita', title: 'La Telesita' },
    { slug: 'el-supay', title: 'El Supay' },
    { slug: 'la-almamula', title: 'La Almamula' }
  ];

  return mitos.map(mito => ({
    params: { slug: mito.slug },
    props: { mito }
  }));
}

const { mito } = Astro.props;

// Leer contenido del archivo
let contenido = { historia: '', historieta: '', guion: '' };
try {
  const filePath = join(process.cwd(), 'contenido', `${mito.slug}-completo.md`);
  const fileContent = readFileSync(filePath, 'utf-8');
  
  // Parsear secciones
  const historiaMatch = fileContent.match(/## Historia Completa\n\n([\s\S]*?)(?=\n## Historieta|$)/);
  const historietaMatch = fileContent.match(/## Historieta\n\n([\s\S]*?)(?=\n## Guion|$)/);
  const guionMatch = fileContent.match(/## Guion para Corto[^\n]*\n\n([\s\S]*?)$/);
  
  contenido = {
    historia: historiaMatch ? historiaMatch[1].trim() : '',
    historieta: historietaMatch ? historietaMatch[1].trim() : '',
    guion: guionMatch ? guionMatch[1].trim() : ''
  };
} catch (e) {
  console.error('Error leyendo archivo:', e);
}
---

<Layout title={mito.title} description={`Leyenda de ${mito.title} - Historia, historieta y guión cinematográfico`}>
  <article class="max-w-4xl mx-auto">
    <!-- Back link -->
    <a href="/" class="inline-flex items-center text-orange-600 hover:text-orange-700 mb-6 transition-colors">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Volver al inicio
    </a>

    <!-- Header -->
    <header class="mb-8">
      <span class="inline-block px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-sm font-medium mb-4">
        Leyenda Santiagueña
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 font-['DM_Serif_Display'] mb-4">
        {mito.title}
      </h1>
      <div class="h-1 w-24 bg-orange-500 rounded"></div>
    </header>

    <!-- Tabs -->
    <div class="mb-8">
      <div class="flex border-b border-slate-200">
        <button id="tab-historia" class="tab-btn px-6 py-3 text-sm font-medium text-orange-600 border-b-2 border-orange-600 bg-orange-50/50" onclick="switchTab('historia')">
          📖 Historia
        </button>
        <button id="tab-historieta" class="tab-btn px-6 py-3 text-sm font-medium text-slate-600 border-b-2 border-transparent hover:text-orange-600" onclick="switchTab('historieta')">
          🎨 Historieta
        </button>
        <button id="tab-guion" class="tab-btn px-6 py-3 text-sm font-medium text-slate-600 border-b-2 border-transparent hover:text-orange-600" onclick="switchTab('guion')">
          🎬 Guión
        </button>
      </div>
    </div>

    <!-- Tab Content -->
    <div id="content-historia" class="tab-content">
      <div class="prose prose-lg max-w-none text-slate-700 leading-relaxed">
        {contenido.historia.split('\n\n').map((parrafo) => (
          <p class="mb-4 text-lg leading-relaxed">{parrafo}</p>
        ))}
      </div>
    </div>

    <div id="content-historieta" class="tab-content hidden">
      <div class="space-y-8">
        {contenido.historieta.split('### Escena').filter(Boolean).map((escena, i) => {
          const lines = escena.trim().split('\n');
          const titulo = lines[0]?.replace(':', '').trim() || `Escena ${i + 1}`;
          const descripcion = lines.find(l => l.trim() && !l.includes('**'))?.trim() || '';
          const dialogo = lines.find(l => l.includes('Diálogo:'))?.replace('**Diálogo:**', '').trim() || '';
          const prompt = lines.find(l => l.includes('Prompt:'))?.replace('**Prompt:**', '').trim() || '';
          
          return (
            <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
              <h3 class="text-xl font-bold text-slate-900 font-['DM_Serif_Display'] mb-3">
                Escena {i + 1}: {titulo}
              </h3>
              <p class="text-slate-700 mb-4">{descripcion}</p>
              {dialogo && (
                <div class="bg-white rounded-lg p-4 mb-4 border-l-4 border-orange-500">
                  <p class="text-sm text-slate-500 mb-1">Diálogo:</p>
                  <p class="text-slate-800 italic">{dialogo}</p>
                </div>
              )}
              {prompt && (
                <div class="bg-orange-50 rounded-lg p-4">
                  <p class="text-sm text-orange-600 font-medium mb-2">🎨 Prompt para IA:</p>
                  <code class="text-xs text-slate-700 block break-words">{prompt}</code>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <div id="content-guion" class="tab-content hidden">
      <div class="bg-slate-900 text-slate-100 rounded-xl p-6 font-mono text-sm overflow-x-auto">
        <pre class="whitespace-pre-wrap">{contenido.guion}</pre>
      </div>
    </div>

    <!-- Source -->
    <div class="mt-12 pt-8 border-t border-slate-200">
      <p class="text-sm text-slate-500">
        <strong>Fuente original:</strong>{' '}
        <a href="https://ccbsantiago.gob.ar/creencias-populares-santiaguenas-mitos-y-leyendas/" class="text-orange-600 hover:underline" target="_blank" rel="noopener">
          Centro Cultural del Bicentenario - Santiago del Estero
        </a>
      </p>
      <p class="text-xs text-slate-400 mt-2">
        Contenido ampliado y adaptado con narrativa completa, historieta y guión cinematográfico.
      </p>
    </div>
  </article>

  <script is:inline>
    function switchTab(tabName) {
      // Hide all content
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.getElementById('content-' + tabName).classList.remove('hidden');
      
      // Reset all tabs
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('text-orange-600', 'border-orange-600', 'bg-orange-50/50');
        btn.classList.add('text-slate-600', 'border-transparent');
      });
      
      // Activate selected tab
      document.getElementById('tab-' + tabName).classList.remove('text-slate-600', 'border-transparent');
      document.getElementById('tab-' + tabName).classList.add('text-orange-600', 'border-orange-600', 'bg-orange-50/50');
    }
  </script>
</Layout>